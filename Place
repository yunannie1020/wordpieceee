            if(s.exists()) return alert("이미 가입된 ID입니다.");
            db.ref('users/' + id).set({ pw, nickname: nick, progress: { 3:1, 4:1, 5:1, 6:1, 7:1 } }).then(() => {
                alert("가입 성공! 로그인 해주세요."); toggleAuth(false);
            });
        });
    }

    function handleLogin() {
        const id = document.getElementById('login-id').value.trim().toLowerCase();
        const pw = document.getElementById('login-pw').value;
        if(id === "yun" && pw === "1020") return renderAdmin();
        
        db.ref('users/' + id).once('value').then(s => {
            if(s.exists() && s.val().pw === pw) {
                currentUser = id; currentNick = s.val().nickname; showMenu();
            } else alert("아이디 혹은 비번이 틀립니다.");
        });
    }

    function showMenu() {
        document.getElementById('auth-screen').style.display = 'none';
        document.getElementById('menu-screen').style.display = 'flex';
        document.getElementById('user-info').textContent = `${currentNick}님 환영합니다!`;
        db.ref('users/' + currentUser).on('value', s => {
            const u = s.val();
            if(u) for(let i=3; i<=7; i++) document.getElementById(`rec-${i}`).textContent = `ST ${u.progress[i]}`;
        });
    }

    /* --- Admin Panel --- */
    function renderAdmin() {
        document.getElementById('auth-screen').style.display = 'none';
        document.getElementById('admin-screen').style.display = 'flex';
        db.ref('users').once('value').then(s => {
            let html = "<h4>유저 진도 현황</h4>";
            Object.entries(s.val()).forEach(([id, u]) => {
                html += `<div><b>${u.nickname}</b>(${id}): ${JSON.stringify(u.progress)}</div>`;
            });
            db.ref('reviews').once('value').then(rs => {
                html += "<h4 style='margin-top:20px'>유저 별점/후기</h4>";
                if(rs.exists()) Object.values(rs.val()).forEach(r => {
                    html += `<div>[${r.stars}점] ${r.nick}: ${r.text}</div>`;
                });
                document.getElementById('admin-data-list').innerHTML = html;
            });
        });
    }

    function copyInvite() { navigator.clipboard.writeText(window.location.href); alert("초대 링크가 복사되었습니다!"); }

    /* --- Review Logic --- */
    function openReview() { document.getElementById('review-modal').style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
    function setStar(n) { rating = n; const spans = document.getElementById('star-input').children; for(let i=0; i<5; i++) spans[i].textContent = i < n ? "★" : "☆"; }
    function submitReview() {
        if(rating === 0) return alert("별점을 선택해 주세요!");
        db.ref('reviews').push({ nick: currentNick, stars: rating, text: document.getElementById('review-text').value.trim() || "내용 없음" }).then(() => {
            alert("후기 감사합니다!"); closeModal('review-modal');
        });
    }

    /* --- Game Logic --- */
    let targetWord = "", inventory = [], currentGuess = [], selectedIdx = null, curLevel = 3;
    let attempts = 0, hintsUsed = 0;

    function startGame(level) {
        curLevel = level;
        document.getElementById('menu-screen').style.display = 'none';
        document.getElementById('game-header').style.display = 'flex';
        document.getElementById('main-content').style.display = 'flex';
        document.getElementById('inventory-container').style.display = 'block';
        initRound();
    }

    function initRound() {
        db.ref('users/' + currentUser + '/progress/' + curLevel).once('value').then(s => {
            const stage = s.val() || 1;
            targetWord = wordPool[curLevel][(stage - 1) % 50];
            attempts = 0; hintsUsed = 0; updateStats();
            
            const rawTiles = {};
            for(let char of targetWord) {
                const code = char.charCodeAt(0) - 0xAC00;
                const sp = { cho: CHOSUNG[Math.floor(code/588)], jung: JUNGSUNG[Math.floor((code%588)/28)], jong: JONGSUNG[code%28] };
                [sp.cho, sp.jung, sp.jong].forEach(j => { if(!j) return; const m = baseMap[j] || j; (Array.isArray(m)?m:[m]).forEach(bit => { const r = getBaseType(bit); rawTiles[r] = (rawTiles[r]||0)+1; }); });
            }
            inventory = Object.entries(rawTiles).map(([type, count]) => ({ type, shape: type, count }));
            currentGuess = Array.from({length: targetWord.length}, () => ({cho:'', jung:'', jong:'', status:''}));
            selectedIdx = null; 
            document.getElementById('cur-stage-txt').textContent = `STAGE ${stage}`;
            render();
        });
    }

    function updateStats() {
        document.getElementById('stat-attempts').textContent = attempts;
        document.getElementById('stat-hints').textContent = hintsUsed;
    }

    function render() {
        const poolEl = document.getElementById('tile-pool'); poolEl.innerHTML = '';
        inventory.forEach((item, idx) => {
            const tile = document.createElement('div');
            tile.className = `tile ${item.count <= 0 ? 'disabled' : ''} ${selectedIdx === idx ? 'selected' : ''}`;
            tile.innerHTML = `<b>${item.shape}</b><span>${item.count}</span>`;
            tile.onclick = (e) => { e.stopPropagation(); if(selectedIdx === idx) { const next = rotateMap[item.shape]; if(next) { item.shape = next; render(); } } else if(item.count > 0) { selectedIdx = idx; render(); } };
            poolEl.appendChild(tile);
        });

        const gridEl = document.getElementById('answer-grid'); gridEl.innerHTML = '';
        currentGuess.forEach((char, i) => {
            const box = document.createElement('div');
            box.className = `char-box ${char.status ? 'res-' + char.status : ''}`;
            ['cho','jung','jong'].forEach(t => {
                const s = document.createElement('div'); s.className = `slot ${char[t] ? 'filled' : ''}`; s.textContent = char[t];
                box.appendChild(s);
            });
            box.onclick = (e) => {
                e.stopPropagation();
                if(selectedIdx !== null) {
                    const it = inventory[selectedIdx];
                    const targetPart = !char.cho ? 'cho' : (!char.jung ? 'jung' : 'jong');
                    if(!char.jong) {
                        if(char[targetPart]) {
                            const res = mergeMap[char[targetPart] + it.shape] || mergeMap[it.shape + char[targetPart]];
                            if(res) { char[targetPart] = res; it.count--; if(it.count <= 0) selectedIdx = null; render(); }
                        } else { char[targetPart] = it.shape; it.count--; if(it.count <= 0) selectedIdx = null; render(); }
                    }
                } else {
                    // [도로 빼기] 회수 로직
                    ['cho','jung','jong'].forEach(t => {
                        if(char[t]) {
                            const comps = baseMap[char[t]] || char[t];
                            (Array.isArray(comps) ? comps : [comps]).forEach(c => {
                                const r = getBaseType(c);
                                const inv = inventory.find(invIt => invIt.type === r);
                                if(inv) inv.count++;
                            });
                            char[t] = '';
                        }
                    });
                    char.status = ''; render();
                }
            };
            gridEl.appendChild(box);
        });
    }

    function deselectTile() { selectedIdx = null; render(); }

    function submitGuess() {
        let guessArr = [];
        for(let i=0; i<currentGuess.length; i++) {
            const {cho, jung, jong} = currentGuess[i]; if(!cho || !jung) return alert("글자를 완성해 주세요!");
            guessArr.push(String.fromCharCode(0xAC00 + (CHOSUNG.indexOf(cho)*588) + (JUNGSUNG.indexOf(jung)*28) + JONGSUNG.indexOf(jong)));
        }
        
        attempts++; updateStats();
        let tempT = targetWord.split('');
        guessArr.forEach((g, i) => { if(g === targetWord[i]) { currentGuess[i].status = 'correct'; tempT[i] = null; } });
        guessArr.forEach((g, i) => { 
            if(currentGuess[i].status !== 'correct') { 
                const fIdx = tempT.indexOf(g);
                if(fIdx !== -1) { currentGuess[i].status = 'present'; tempT[fIdx] = null; } 
                else currentGuess[i].status = 'absent'; 
            } 
        });
        render();
        if(guessArr.join('') === targetWord) { 
            setTimeout(() => { 
                alert("🎉 정답입니다!"); 
                db.ref('users/' + currentUser + '/progress/' + curLevel).transaction(s => (s || 1) + 1);
                initRound(); 
            }, 100);
        }
    }

    function giveHint() { hintsUsed++; updateStats(); alert(`첫 글자 힌트: "${targetWord[0]}"`); }
    function goBack() { document.getElementById('game-header').style.display = 'none'; document.getElementById('main-content').style.display = 'none'; document.getElementById('inventory-container').style.display = 'none'; showMenu(); }
    function revealAnswer() { if(confirm(`정답: [ ${targetWord} ]\n다음으로 넘어갈까요?`)) { 
        db.ref('users/' + currentUser + '/progress/' + curLevel).transaction(s => (s || 1) + 1);
        initRound(); 
    } }
</script>
