<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>언어의 조각 : Masterpiece</title>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-database-compat.js"></script>
    <style>
        :root {
            --bg: #121213; --card: #1a1a1b; --text: #ffffff; --border: #3a3a3c;
            --primary: #538d4e;   /* Correct - 초록 */
            --secondary: #b59f3b; /* Present - 노랑 */
            --absent: #e74c3c;    /* Wrong - 빨강 */
            --selected: #3498db; --empty: #121213;
        }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; font-family: 'Pretendard', sans-serif; }
        body { background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; height: 100dvh; overflow: hidden; }

        .full-screen { position: fixed; top:0; left:0; width:100%; height:100%; background: var(--bg); z-index: 2000; padding: 20px; display: none; flex-direction: column; justify-content: center; align-items: center; }
        #auth-screen { display: flex; }
        .card { background: var(--card); padding: 32px; border-radius: 20px; width: 100%; max-width: 360px; text-align: center; border: 1px solid var(--border); box-shadow: 0 8px 30px rgba(0,0,0,0.5); }
        h1 { font-size: 1.8rem; margin: 0 0 20px; font-weight: 800; color: var(--selected); }
        
        input, textarea { background: var(--empty); border: 2px solid var(--border); color: #fff; padding: 14px; border-radius: 12px; width: 100%; margin-bottom: 12px; font-size: 1rem; outline: none; }
        button { cursor: pointer; border: none; font-weight: bold; border-radius: 12px; transition: 0.2s; padding: 14px; font-size: 1rem; }
        .btn-main { background: var(--selected); color: #fff; width: 100%; }
        .btn-sub { background: none; color: #888; font-size: 0.85rem; margin-top: 12px; }

        .lvl-btn { background: var(--card); border: 1px solid var(--border); color: #fff; margin-bottom: 10px; width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 18px; }
        .lvl-btn span { color: var(--selected); font-size: 0.8rem; }

        header { padding: 10px 20px; display: none; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
        .stat-bar { font-size: 0.75rem; color: #888; display: flex; gap: 12px; margin-bottom: 10px; justify-content: center; width: 100%; }
        .stat-bar b { color: var(--selected); }

        #main-content { flex: 1; display: none; flex-direction: column; justify-content: center; align-items: center; padding: 10px; width: 100%; max-width: 500px; margin: 0 auto; }
        
        #answer-grid { display: flex; gap: 6px; justify-content: center; width: 100%; margin: 10px 0; }
        .char-box { display: flex; flex-direction: column; gap: 4px; padding: 6px; background: var(--card); border-radius: 8px; border: 2px solid var(--border); flex: 1; max-width: 60px; transition: 0.3s; }
        .slot { height: 32px; background: var(--empty); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 1rem; font-weight: 800; border: 1px solid #333; pointer-events: none; }

        #inventory-container { background: #1a1a1b; border-top: 1px solid var(--border); padding: 15px; display: none; }
        .inventory-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; max-width: 400px; margin: 0 auto; }
        .tile { aspect-ratio: 1/1; background: var(--card); border: 2px solid var(--border); border-radius: 10px; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; }
        .tile b { font-size: 1.2rem; }
        .tile span { font-size: 0.65rem; color: var(--selected); font-weight: 900; }
        .tile.selected { border-color: var(--selected); background: #2c3e50; box-shadow: 0 0 15px rgba(52, 152, 219, 0.4); transform: translateY(-4px); }

        .controls { display: flex; gap: 8px; width: 100%; padding: 0 10px; margin-top: 15px; }
        .btn-game { flex: 1; background: #444; color: #fff; }
        .btn-submit { flex: 2; background: var(--primary); color: #fff; }

        .res-correct { background: var(--primary) !important; border-color: var(--primary) !important; }
        .res-present { background: var(--secondary) !important; border-color: var(--secondary) !important; }
        .res-absent { background: var(--absent) !important; border-color: var(--absent) !important; }

        .admin-section { width: 100%; text-align: left; margin-top: 20px; font-size: 0.8rem; color: #aaa; max-height: 250px; overflow-y: auto; background: #000; padding: 10px; border-radius: 10px; }
    </style>
</head>
<body onclick="deselectTile()">

<div id="auth-screen" class="full-screen" onclick="event.stopPropagation()">
    <div class="card" id="login-box">
        <h1>LOGIN</h1>
        <input type="text" id="login-id" placeholder="ID">
        <input type="password" id="login-pw" placeholder="PIN (4자)">
        <button class="btn-main" onclick="handleLogin()">입장하기</button>
        <button class="btn-sub" onclick="toggleAuth(true)">신규 가입하기</button>
    </div>
    <div class="card" id="signup-box" style="display:none;">
        <h1>SIGN UP</h1>
        <input type="text" id="signup-id" placeholder="사용할 ID">
        <input type="text" id="signup-nick" placeholder="닉네임 (한글 가능)">
        <input type="password" id="signup-pw" placeholder="PIN (4자)">
        <button class="btn-main" style="background:var(--secondary)" onclick="handleSignup()">가입 완료</button>
        <button class="btn-sub" onclick="toggleAuth(false)">로그인으로 돌아가기</button>
    </div>
</div>

<div id="menu-screen" class="full-screen" onclick="event.stopPropagation()">
    <h1 style="color:var(--selected)">언어의 조각</h1>
    <p id="user-info" style="margin-bottom:20px; opacity:0.8;"></p>
    <div style="width:100%; max-width:340px;">
        <button class="lvl-btn" onclick="startGame(3)">3글자 퍼즐 <span id="rec-3">-</span></button>
        <button class="lvl-btn" onclick="startGame(4)">4글자 퍼즐 <span id="rec-4">-</span></button>
        <button class="lvl-btn" onclick="startGame(5)">5글자 퍼즐 <span id="rec-5">-</span></button>
        <button class="lvl-btn" onclick="startGame(6)">6글자 퍼즐 <span id="rec-6">-</span></button>
        <button class="lvl-btn" onclick="startGame(7)">7글자 퍼즐 <span id="rec-7">-</span></button>
        <button onclick="openReview()" style="width:100%; background:#2c3e50; color:#fff; margin-top:10px;">⭐ 별점 및 후기 남기기</button>
        <button onclick="renderAdmin()" id="admin-view-btn" style="width:100%; background:#000; color:var(--selected); margin-top:10px; display:none;">📊 관리자 패널</button>
        <button onclick="location.reload()" style="width:100%; background:none; color:#ff4d4d; margin-top:20px; font-size:0.8rem;">로그아웃</button>
    </div>
</div>

<div id="admin-screen" class="full-screen" onclick="event.stopPropagation()">
    <div class="card" style="max-width: 500px;">
        <h1>ADMIN</h1>
        <button class="btn-main" onclick="copyInvite()" style="background:var(--secondary); margin-bottom:15px;">🔗 초대 링크 복사</button>
        <div id="admin-data-list" class="admin-section"></div>
        <button class="btn-sub" onclick="location.reload()">나가기</button>
    </div>
</div>

<header id="game-header">
    <h2 style="margin:0; color:var(--selected); font-size:1rem;">언어의 조각</h2>
    <button onclick="goBack()" style="background:var(--absent); color:#fff; border-radius:8px; padding:6px 12px; font-size:0.8rem;">나가기</button>
</header>
<div id="main-content" onclick="event.stopPropagation()">
    <div class="stat-bar">
        <span>시도: <b id="stat-attempts">0</b></span>
        <span>힌트: <b id="stat-hints">0</b></span>
        <span id="cur-stage-txt"></span>
    </div>
    <div id="answer-grid"></div>
    <div class="controls">
        <button id="hint-btn" class="btn-game" onclick="giveHint()">힌트</button>
        <button id="submit-btn" class="btn-submit" onclick="submitGuess()">제출하기</button>
        <button id="reveal-btn" class="btn-game" onclick="revealAnswer()">정답</button>
    </div>
</div>
<div id="inventory-container" onclick="event.stopPropagation()">
    <div id="tile-pool" class="inventory-grid"></div>
</div>

<div id="review-modal" class="modal">
    <div class="modal-content">
